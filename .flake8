[flake8]
max-line-length = 88
extend-ignore =
    E203,  # whitespace before ':'
    E501,  # line too long
    W503,  # line break before binary operator
    E731,  # do not assign a lambda expression, use a def
    F401,  # imported but unused
    F403,  # 'from module import *' used; unable to detect undefined names
    F405,  # name may be undefined, or defined from star imports
    E402,  # module level import not at top of file
    C901,  # too complex
    B008,  # do not perform function calls in argument defaults
    B006,  # do not use mutable data structures for argument defaults
    B007,  # loop control variable not used within the loop body
    B009,  # do not call getattr with a constant attribute value
    B010,  # do not call setattr with a constant attribute value
    B011,  # do not call assert False since python -O removes these calls
    B012,  # return/yeild/break/continue inside finally
    B013,  # redundant tuple in exception handler
    B014,  # exception handler does not do anything
    B015,  # pointless comparison
    B016,  # cannot raise a literal
    B017,  # assertRaises(Exception) should be considered evil
    B018,  # useless expression
    B019,  # use of functools.lru_cache on methods
    B020,  # loop control variable overrides iterable it iterates
    B021,  # f-string used as docstring
    B022,  # no arguments passed to contextlib.suppress
    B023,  # function definition does not bind loop variable
    B024,  # abstract base class with no abstract methods
    B025,  # try-except with duplicate exception
    B026,  # star-arg unpacking after keyword argument
    B027,  # empty method in abstract base class
    B028,  # no explicit stacklevel keyword argument found
    B029,  # except with empty tuple
    B030,  # except with too broad exception
    B031,  # re-use of loop variable in comprehension
    B032,  # possible unintentional type annotation
    B033,  # duplicate value in set
    B034,  # re-use of variable name in comprehension
    B035,  # static key in dict comprehension
    B036,  # don't except: pass
    B037,  # except handler re-raises unconditionally
    B038,  # use of ==/!= with string literal
    B039,  # mutable default argument
    B040,  # except handler does not handle the exception
    B041,  # multiple except handlers for same exception
    B042,  # except handler re-raises unconditionally
    B043,  # exception handler does not handle the exception
    B044,  # except handler re-raises unconditionally
    B045,  # exception handler does not handle the exception
    B046,  # except handler re-raises unconditionally
    B047,  # exception handler does not handle the exception

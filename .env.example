# Alfredo AI - Configurações de Ambiente
# Copie este arquivo para .env e configure conforme necessário

# Configurações básicas
WHISPER_MODEL=base
DEFAULT_LANGUAGE=pt
LOG_LEVEL=INFO

# Para download do YouTube (opcional)
# GROQ_API_KEY=your-groq-api-key-here

# Configurações do YouTube
YOUTUBE_QUALITY=best
YOUTUBE_FORMAT=mp4

# Configurações de Cache
CACHE_ENABLED=true
CACHE_DIR=data/temp/cache
CACHE_TTL_HOURS=24

# Configurações de Segurança
MAX_VIDEO_DURATION_MIN=120
ALLOWED_EXTENSIONS=mp4,mkv,avi,mov,wmv,flv,webm,m4v

# Configurações de Performance
WHISPER_MODEL=base
TRANSCRIPTION_TIMEOUT=300
PROCESSING_THREADS=2

# Configurações de Notificação
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_TO=recipient@example.com

# Configurações de Armazenamento
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_BUCKET_NAME=your_bucket
# AWS_REGION=us-east-1

# Configurações de Monitoramento
# SENTRY_DSN=your_sentry_dsn
# TELEMETRY_ENABLED=false

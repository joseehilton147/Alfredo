# Alfredo AI - Configuração de Ambiente
# Copie este arquivo para .env e configure suas chaves

# Chave de API do Groq (obrigatória)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Configurações de Log
LOG_LEVEL=INFO
LOG_FILE=data/logs/alfredo.log

# Configurações de Processamento
MAX_CONCURRENT_JOBS=3
DEFAULT_LANGUAGE=pt
MAX_FILE_SIZE_MB=500

# Configurações de Saída
OUTPUT_FORMAT=json
SAVE_TRANSCRIPTION=true
SAVE_SUMMARY=true

# Configurações do YouTube
YOUTUBE_QUALITY=best
YOUTUBE_FORMAT=mp4

# Configurações de Cache
CACHE_ENABLED=true
CACHE_DIR=data/temp/cache
CACHE_TTL_HOURS=24

# Configurações de Segurança
MAX_VIDEO_DURATION_MIN=120
ALLOWED_EXTENSIONS=mp4,mkv,avi,mov,wmv,flv,webm,m4v

# Configurações de Performance
WHISPER_MODEL=base
TRANSCRIPTION_TIMEOUT=300
PROCESSING_THREADS=2

# Configurações de Notificação
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=your_email@gmail.com
# EMAIL_PASSWORD=your_app_password
# EMAIL_TO=recipient@example.com

# Configurações de Armazenamento
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_BUCKET_NAME=your_bucket
# AWS_REGION=us-east-1

# Configurações de Monitoramento
# SENTRY_DSN=your_sentry_dsn
# TELEMETRY_ENABLED=false
